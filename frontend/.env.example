# Copy this to .env.local and fill in as needed.
# .env.local is git-ignored by default.

# Override where the app fetches name data from.
# Useful if you host data/ on a CDN rather than bundling with the app.
# Default: ./data (relative to public/ folder — works on GitHub Pages)
# REACT_APP_DATA_URL=https://your-cdn.example.com/baby-name-data
